source("scripts/NBA_synergy_copy.R")
dir.create("scripts/data", showWarnings = FALSE)
# Save all seasons' shooting data
for (year in 2013:2026) {
szn <- paste0(year, "-", substr(year+1, 3, 4))
cat("Downloading", szn, "\n")
# Players data
players <- filter_shooting_data(szn = szn, player = 'Player')
write.csv(players, paste0("scripts/data/shooting_", szn, ".csv"), row.names = FALSE)
# Teams data (for chart_ovd)
teams <- filter_shooting_data(szn = szn, player = 'Team')
write.csv(teams, paste0("scripts/data/teams_", szn, ".csv"), row.names = FALSE)
Sys.sleep(1)
}
